{
    "name": "evgenmil/webhook-storage",
    "description": "Framework-agnostic webhook storage layer for PHP. Per-source MySQL tables, single schema, status lifecycle.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "evgenmil\\WebhookStorage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "evgenmil\\WebhookStorage\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit"
    },
    "minimum-stability": "stable"
}
